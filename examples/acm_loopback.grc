options:
  parameters:
    author: Pasindu Manujaya
    catch_exceptions: 'True'
    category: '[GRC Hier Blocks]'
    cmake_opt: ''
    comment: ''
    copyright: ''
    description: 'DVB-S2 ACM Closed-Loop Software Simulation. Full TX -> LEO Channel
      -> AWGN -> RX -> ACM Controller -> feedback loop entirely in software. Architecture:
      Random Source -> BB Framer -> FEC Encoder -> Modulator -> PL Framer -> Throttle
      -> LEO Channel -> AWGN Channel -> PL Sync -> SNR Estimator -> Demodulator ->
      FEC Decoder -> ACM Feedback -> ACM Controller -> BB Framer (loopback).'
    gen_cmake: 'On'
    gen_linking: dynamic
    generate_options: qt_gui
    hier_block_src_path: '.:'
    id: acm_loopback
    max_nouts: '0'
    output_language: python
    placement: (0,0)
    qt_qss_theme: ''
    realtime_scheduling: ''
    run: 'True'
    run_command: '{python} -u {filename}'
    run_options: prompt
    sizing_mode: fixed
    thread_safe_setters: ''
    title: DVB-S2 ACM Loopback Simulation
    window_size: (1400, 900)
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 8]
    rotation: 0
    state: enabled

blocks:
- name: initial_modcod
  id: variable
  parameters:
    comment: QPSK 1/2 = safe initial MODCOD
    value: '4'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [520, 8]
    rotation: 0
    state: enabled
- name: rain_rate
  id: variable_qtgui_range
  parameters:
    comment: Rain attenuation slider (ITU-R P.618-13)
    gui_hint: tab@0:1,0,1,2
    label: Rain Rate (mm/hr)
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '0'
    step: '1'
    stop: '50'
    value: '5'
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [840, 8]
    rotation: 0
    state: enabled
- name: samp_rate
  id: variable
  parameters:
    comment: Sample rate = symbol rate
    value: symbol_rate
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [360, 8]
    rotation: 0
    state: enabled
- name: snr_db
  id: variable_qtgui_range
  parameters:
    comment: AWGN noise level. Measured SNR = snr_db - 16.6 dB at TCA.
    gui_hint: tab@0:0,0,1,2
    label: SNR (dB)
    min_len: '200'
    orient: QtCore.Qt.Horizontal
    rangeType: float
    start: '20'
    step: '0.5'
    stop: '50'
    value: '33'
    widget: counter_slider
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [680, 8]
    rotation: 0
    state: enabled
- name: symbol_rate
  id: variable
  parameters:
    comment: 5 Msps DVB-S2 symbol rate
    value: 5e6
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [200, 8]
    rotation: 0
    state: enabled
- name: acm_controller
  id: dvbs2acm_acm_controller
  parameters:
    acm_mode: dvbs2acm.AcmMode.ACM
    affinity: ''
    ai_socket: '"tcp://localhost:5557"'
    alias: ''
    comment: "ACM DECISION BLOCK. Selects optimal MODCOD based on measured SNR+BER.\
      \ modcod_out \u2192 BB Framer modcod_in = loopback feedback (simulated return\
      \ channel). Enable AI/ML: start acm_controller_ai.py then set use_ai=True."
    frame_size: dvbs2acm.FrameSize.NORMAL
    history_len: '16'
    hysteresis_db: '0.5'
    initial_modcod: initial_modcod
    maxoutbuf: '0'
    minoutbuf: '0'
    snr_margin_db: '1.0'
    target_ber: 1e-7
    use_ai: 'True'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1336, 852.0]
    rotation: 0
    state: enabled
- name: acm_feedback
  id: dvbs2acm_acm_feedback
  parameters:
    affinity: ''
    alias: ''
    ber_alpha: '0.05'
    comment: Aggregates SNR (from SNR Estimator) and BER/FER (from FEC Decoder) into
      a single feedback message for the ACM Controller.
    maxoutbuf: '0'
    minoutbuf: '0'
    report_period_ms: '100.0'
    snr_alpha: '0.1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1616, 568]
    rotation: 0
    state: enabled
- name: analog_random_source
  id: analog_random_source_x
  parameters:
    affinity: ''
    alias: ''
    comment: Simulated transport stream data (MPEG-TS)
    max: '256'
    maxoutbuf: '0'
    min: '0'
    minoutbuf: '0'
    num_samps: '1000'
    repeat: 'True'
    type: byte
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [8, 264.0]
    rotation: 0
    state: enabled
- name: awgn_channel
  id: channels_channel_model
  parameters:
    affinity: ''
    alias: ''
    block_tags: 'False'
    comment: "AWGN noise channel. Noise amplitude = 10^(-snr_db/20). Measured SNR\
      \ at SNR Estimator = snr_db - 16.6 dB (signal chain power offset). Default snr_db=33\
      \ -> TCA SNR\u224816.4 dB, AOS/LOS SNR\u22484.2 dB."
    epsilon: '1.0'
    freq_offset: '0.0'
    maxoutbuf: '0'
    minoutbuf: '0'
    noise_voltage: '0'
    seed: '0'
    taps: '1.0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [736, 624.0]
    rotation: 0
    state: enabled
- name: bb_framer
  id: dvbs2acm_bb_framer_acm
  parameters:
    affinity: ''
    alias: ''
    comment: 'TX: BB Framer. ACM Controller feeds MODCOD back here via modcod_in message
      port (loopback feedback = simulated return channel).'
    frame_size: dvbs2acm.FrameSize.NORMAL
    initial_modcod: initial_modcod
    maxoutbuf: '0'
    minoutbuf: '0'
    pilots: 'True'
    stream_type: dvbs2acm.StreamType.TRANSPORT
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [248, 280.0]
    rotation: 0
    state: enabled
- name: demodulator
  id: dvbs2acm_demodulator_acm
  parameters:
    affinity: ''
    alias: ''
    comment: 'RX: soft-decision max-log LLR demodulation'
    initial_modcod: initial_modcod
    maxoutbuf: '0'
    minoutbuf: '0'
    noise_var: '0.1'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1328, 528.0]
    rotation: 0
    state: enabled
- name: fec_decoder
  id: dvbs2acm_fec_decoder_acm
  parameters:
    affinity: ''
    alias: ''
    comment: 'RX: iterative LDPC + BCH FEC decoding. Publishes BER/FER to ber_out.'
    frame_size: dvbs2acm.FrameSize.NORMAL
    initial_modcod: initial_modcod
    ldpc_algorithm: dvbs2acm.LdpcAlgorithm.ONESIDE
    max_iter: '20'
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1664, 384]
    rotation: 0
    state: enabled
- name: fec_encoder
  id: dvbs2acm_fec_encoder_acm
  parameters:
    affinity: ''
    alias: ''
    comment: 'TX: BCH outer + LDPC inner FEC encoder. All 28 MODCODs supported.'
    frame_size: dvbs2acm.FrameSize.NORMAL
    initial_modcod: initial_modcod
    ldpc_algorithm: dvbs2acm.LdpcAlgorithm.ONESIDE
    maxoutbuf: '0'
    minoutbuf: '0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [632, 288.0]
    rotation: 0
    state: enabled
- name: leo_channel
  id: dvbs2acm_leo_channel
  parameters:
    affinity: ''
    alias: ''
    altitude_km: '500.0'
    comment: Physics-based LEO channel at 500 km, X-Band 8.025 GHz. Applies FSPL,
      Doppler (+/-188 kHz), rain, scintillation, Rician fading. Publishes channel_state
      messages.
    fading_coherence_s: '30.0'
    freq_hz: 8.025e9
    maxoutbuf: '0'
    min_elevation_deg: '5.0'
    minoutbuf: '0'
    noise_temp_k: '150.0'
    rain_rate_mm_hr: rain_rate
    rx_gain_dbi: '37.0'
    sample_rate: samp_rate
    snr_offset_db: '0.0'
    time_acceleration: '10.0'
    tx_gain_dbi: '10.0'
    tx_power_dbw: '0.0'
    update_period_ms: '100.0'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [392, 548.0]
    rotation: 0
    state: enabled
- name: modulator
  id: dvbs2acm_modulator_acm
  parameters:
    affinity: ''
    alias: ''
    comment: 'TX: constellation mapper (QPSK/8PSK/16APSK/32APSK). ACM-switched per
      frame.'
    initial_modcod: initial_modcod
    maxoutbuf: '0'
    minoutbuf: '0'
    rolloff: '0.2'
  states:
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1024, 296.0]
    rotation: 0
    state: enabled
- name: null_sink
  id: blocks_null_sink
  parameters:
    affinity: ''
    alias: ''
    bus_structure_sink: '[[0,],]'
