    coordinate: [1096, 848.0]
    rotation: 0
    state: enabled
- name: pl_framer
  id: dvbs2acm_pl_framer_acm
  parameters:
    affinity: ''
    alias: ''
    comment: 'TX: PL Header (90 syms: SOF + PLSCODE), pilot blocks, Gold code scrambling'
