    bus_source: false
    bus_structure: null
    coordinate: [56, 416.0]
    rotation: 0
    state: enabled
- name: pl_sync
  id: dvbs2acm_pl_sync_acm
  parameters:
    affinity: ''
    alias: ''
    avg_frames: '4'
    comment: 'RX: SOF correlation, PLSCODE RM decoding, PLL, Gold descrambling. Tags
